@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">EventEase Dashboard</h1>
        <p class="lead text-muted">Manage your venues, schedule events, and track bookings all in one place.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="display-5 text-primary mb-3">
                        <i class="bi bi-building"></i>
                    </div>
                    <h3 class="card-title h4">Venues</h3>
                    <p class="card-text text-muted">View all available university locations and college halls.</p>
                    <a asp-controller="Venues" asp-action="Index" class="btn btn-primary w-100 mt-3">Manage Venues</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="display-5 text-success mb-3">
                        <i class="bi bi-calendar-event"></i>
                    </div>
                    <h3 class="card-title h4">Events</h3>
                    <p class="card-text text-muted">Schedule and organize your upcoming university showdowns.</p>
                    <a asp-controller="Events" asp-action="Index" class="btn btn-success w-100 mt-3 text-white">Manage Events</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="display-5 text-info mb-3">
                        <i class="bi bi-journal-check"></i>
                    </div>
                    <h3 class="card-title h4">Bookings</h3>
                    <p class="card-text text-muted">Link events to venues and track current booking statuses.</p>
                    <a asp-controller="Bookings" asp-action="Index" class="btn btn-info w-100 mt-3 text-white">Manage Bookings</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 bg-light rounded-3 border">
        <div class="row text-center">
            <div class="col-md-12">
                <h4 class="text-muted mb-0 font-weight-light">Ready to organize? Start by creating a <strong>Venue</strong> first!</h4>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}