@{
    ViewData["Title"] = "Elite Dashboard";
}

<div class="container py-5 mt-4">
    <div class="row pt-4 pb-5 align-items-center">
        <div class="col-lg-10">
            <h1 class="fw-black text-uppercase tracking-tight mb-4" style="font-size: 3.5rem; letter-spacing: -2px;">
                EVENT<span class="text-primary hero-glow-text">EASE</span>: ELITE <br />ADMINISTRATIVE PORTAL
            </h1>
            <p class="text-muted fw-bold fs-5 mb-5" style="max-width: 800px;">
                Our precision engineered booking system prevents conflicts and empowers
                specialists to deliver seamless venue coordination across the directory.
            </p>
            <div class="d-flex gap-3">
                <a asp-controller="Bookings" asp-action="Create" class="btn btn-brand-elite py-3 px-5 shadow-sm">START NEW BOOKING</a>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4 col-dashboard">
            <a asp-controller="Venues" asp-action="Index" class="dashboard-bubble shadow-sm">
                <i class="bi bi-building-gear"></i>
                <h3 class="fw-black text-uppercase mb-2">Venues</h3>
                <p class="text-muted small fw-bold mb-0">Browse university locations and high capacity halls.</p>
            </a>
        </div>
        <div class="col-md-4 col-dashboard">
            <a asp-controller="Events" asp-action="Index" class="dashboard-bubble shadow-sm">
                <i class="bi bi-calendar4-event"></i>
                <h3 class="fw-black text-uppercase mb-2">Events</h3>
                <p class="text-muted small fw-bold mb-0">Pre-load and organize upcoming university showdowns.</p>
            </a>
        </div>
        <div class="col-md-4 col-dashboard">
            <a asp-controller="Bookings" asp-action="Index" class="dashboard-bubble shadow-sm">
                <i class="bi bi-shield-check"></i>
                <h3 class="fw-black text-uppercase mb-2">Bookings</h3>
                <p class="text-muted small fw-bold mb-0">Monitor active links and prevent double bookings.</p>
            </a>
        </div>
    </div>

    <div class="row py-5 mt-5 border-top">
        <div class="col-12">
            <h3 class="fw-black text-uppercase mb-4" style="letter-spacing: -1px;">System <span class="text-primary hero-glow-text">Directives</span></h3>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="p-4 bg-white border rounded-4 shadow-sm h-100">
                        <span class="stat-pill mb-3 d-inline-block">DATA INTEGRITY</span>
                        <h5 class="fw-black text-uppercase small mb-2">Secure Storage</h5>
                        <p class="text-muted small fw-bold mb-0">Information is restricted to authorized specialists only.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 bg-white border rounded-4 shadow-sm h-100">
                        <span class="stat-pill mb-3 d-inline-block">INFRASTRUCTURE</span>
                        <h5 class="fw-black text-uppercase small mb-2">Cloud Readiness</h5>
                        <p class="text-muted small fw-bold mb-0">Built to support future transitions to cloud environments.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 bg-white border rounded-4 shadow-sm h-100">
                        <span class="stat-pill mb-3 d-inline-block">UX PRECISION</span>
                        <h5 class="fw-black text-uppercase small mb-2">Advanced Search</h5>
                        <p class="text-muted small fw-bold mb-0">Deep filtering for locations, capacity, and unique IDs.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>