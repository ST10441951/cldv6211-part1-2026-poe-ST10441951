@* EventEase Elite - Security Protocols
    Author: Joshua Marc Lourens
    Description: Outlines data governance and security protocols.
    Uses the 'venue-card-manage' layout to create a focused info-desk panel.
*@

@{
    ViewData["Title"] = "Security Protocols";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="venue-card-manage p-5">
                
                @* --- PROTOCOL HEADER --- *@
                <h1 class="fw-black text-uppercase mb-3 tracking-tight hero-glow-text" style="font-size: 2.8rem;">
                    PRIVACY & <span class="text-primary">DATA SECURITY</span>
                </h1>
                <p class="text-muted fw-bold small text-uppercase mb-5" style="letter-spacing: 2px;">
                    Authorized Administrative Protocols for 2026
                </p>

                @* --- SECURITY PILLARS ---
                   Splitting protocols into Specialist Clearance and Conflict Prevention.
                   These align with Phase 2 and 3 system requirements.
                *@
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <div class="p-4 bg-light rounded-4 h-100 border">
                            <h4 class="fw-black text-uppercase small mb-3 text-primary">Specialist Clearance</h4>
                            <p class="text-muted small fw-bold mb-0">
                                Access to the EventEase platform is strictly restricted to authorized booking specialists.
                                Every update to venue capacity or locations is logged for internal auditing.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4 bg-light rounded-4 h-100 border">
                            <h4 class="fw-black text-uppercase small mb-3 text-primary">Conflict Prevention</h4>
                            <p class="text-muted small fw-bold mb-0">
                                Our precision engine automatically scans schedules to prevent double bookings.
                                Venues with active links cannot be removed from the registry.
                            </p>
                        </div>
                    </div>
                </div>

                @* --- CORE DATA REQUIREMENTS ---
                   Using 'stat-pill' classes to visually tag the core data types 
                   managed by the system, ensuring specialized visibility.
                *@
                <div class="border-top pt-4">
                    <h5 class="fw-black text-uppercase small mb-3">Core Data Requirements</h5>
                    <p class="text-muted small fw-bold mb-4">
                        As mandated by the CEO, our system maintains secure records of the following administrative data:
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="stat-pill">UNIQUE BOOKING IDS</span>
                        <span class="stat-pill">VENUE LOCATIONS</span>
                        <span class="stat-pill">MAX CAPACITY METRICS</span>
                        <span class="stat-pill">AZURE MEDIA METADATA</span>
                    </div>
                </div>

                @* --- NAVIGATIONAL RETURN --- *@
                <div class="mt-5 pt-4 border-top">
                    <a asp-action="Index" class="fw-black text-primary text-decoration-none small">
                        <i class="bi bi-arrow-left me-2"></i> RETURN TO DASHBOARD
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. Data Governance: Principles of administrative accountability in internal systems.
   2. Referential Integrity: Logic for preventing the deletion of linked entities (Venues/Events).
   3. Conflict Detection: Algorithms for temporal data validation in scheduling.
   4. UI Semantics: Use of Stat Pills for specialized attribute classification.
*@