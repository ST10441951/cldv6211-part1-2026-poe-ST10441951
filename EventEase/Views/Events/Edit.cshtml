@* EventEase Elite - Modify Booking
    Author: Joshua Marc Lourens
    Description: High-precision record updating. 
    Maintains the same conflict-prevention styling as the creation panel.
*@

@model EventEase.Models.Booking

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="venue-card-manage p-5 shadow-sm">
                <h2 class="fw-black text-uppercase mb-4" style="letter-spacing: -1.5px;">
                    MODIFY <span class="text-primary hero-glow-text">BOOKING</span>
                </h2>
                
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small fw-bold mb-4 py-2"></div>
                    
                    @* Hidden ID field ensures we target the correct record during the POST back *@
                    <input type="hidden" asp-for="BookingID" />

                    <div class="mb-3">
                        <label class="fw-black small text-muted text-uppercase mb-2 d-block" style="letter-spacing: 1px;">Venue Allocation</label>
                        <select asp-for="VenueID" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" asp-items="ViewBag.VenueID"></select>
                    </div>

                    <div class="mb-3">
                        <label class="fw-black small text-muted text-uppercase mb-2 d-block" style="letter-spacing: 1px;">Linked Event</label>
                        <select asp-for="EventID" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" asp-items="ViewBag.EventID"></select>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="fw-black small text-muted text-uppercase mb-2 d-block">Update Start</label>
                            <input asp-for="BookingStartDate" type="date" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-black small text-muted text-uppercase mb-2 d-block">Update End</label>
                            <input asp-for="BookingEndDate" type="date" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="fw-black small text-muted text-uppercase mb-2 d-block">Current Status</label>
                        <select asp-for="BookingStatus" class="form-control border-0 bg-light p-3 rounded-4 fw-bold">
                            <option value="Pending">Pending</option>
                            <option value="Confirmed">Confirmed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-brand-elite py-3">SAVE CHANGES</button>
                        <a asp-action="Index" class="fw-black text-muted text-center text-decoration-none small">DISCARD AND RETURN</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. HTTP POST Pattern: Edit-mode record updates with primary key preservation.
   2. SelectList Overload: Automatically selecting the active value from the database.
   3. UI Uniformity: Maintaining a mirrored design between Create and Edit workflows.
*@