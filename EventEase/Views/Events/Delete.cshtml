@* EventEase Elite - Purge Booking
    Author: Joshua Marc Lourens
    Description: Permanent decommissioning of a booking record. 
    Implements a distinct 'Purge' aesthetic using high-alert red tones.
*@

@model EventEase.Models.Booking

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 text-center">
            @* Border accent ensures the specialist is aware of the destructive action *@
            <div class="venue-card-manage p-5 shadow-sm border-danger border-opacity-25">
                <div class="mb-4">
                    <i class="bi bi-shield-slash-fill text-danger" style="font-size: 3.5rem;"></i>
                </div>
                
                <h2 class="fw-black text-uppercase mb-3" style="letter-spacing: -1px;">
                    PURGE <span class="text-danger">RECORD</span>
                </h2>
                
                <p class="text-muted fw-bold small mb-5" style="letter-spacing: 1px;">
                    THIS WILL REMOVE THE LINKED DATA PERMANENTLY.
                </p>

                @* Verification block re-stating the ID and event for specialist final checks *@
                <div class="bg-light p-4 rounded-4 mb-5 text-start border">
                    <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.7rem;">Booking Reference</div>
                    <div class="fw-black h5 m-0 text-dark">#@Model.BookingID</div>
                    <hr class="my-3 opacity-10">
                    <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.7rem;">Assigned Event</div>
                    <div class="fw-bold small text-muted">@Model.Event?.EventName</div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="BookingID" />
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-brand-elite py-3 shadow-sm" style="background: #dc3545 !important;">
                            PURGE FROM SYSTEM
                        </button>
                        <a asp-action="Index" class="fw-black text-muted text-decoration-none small">
                            CANCEL AND RETAIN LINK
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. Data Purging Patterns: Principles of irreversible administrative deletions.
   2. UI Color Psychology: Application of the 'Danger' palette for critical warnings.
   3. Razor Conditional Check: Verifying navigation properties during final deletion steps.
*@