@model IEnumerable<EventEase.Models.Event>
@{
    ViewData["Title"] = "Events Directory";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 text-primary"><i class="bi bi-calendar-event me-2"></i>Events Directory</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Create New Event
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="d-flex">
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted border-end-0">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0 ps-0" placeholder="Search events by name or description..." />
                    <button type="submit" class="btn btn-primary px-4">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-3">Clear</a>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Event Details</th>
                        <th>Associated Venue</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary">@item.EventName</div>
                                    <div class="text-muted small text-truncate" style="max-width: 200px;">@item.EventDescription</div>
                                </td>
                                <td>
                                    @if (item.Venue != null)
                                    {
                                        <span><i class="bi bi-geo-alt-fill text-danger me-1"></i>@item.Venue.VenueName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><em>No Venue Linked</em></span>
                                    }
                                </td>
                                <td><span class="badge bg-light text-dark border">@item.EventStartDate.ToString("dd MMM yyyy")</span></td>
                                <td><span class="badge bg-light text-dark border">@item.EventEndDate.ToString("dd MMM yyyy")</span></td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.EventID" class="btn btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.EventID" class="btn btn-outline-info" title="Details"><i class="bi bi-info-circle"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.EventID" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x d-block fs-1 mb-2"></i>
                                No events found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>