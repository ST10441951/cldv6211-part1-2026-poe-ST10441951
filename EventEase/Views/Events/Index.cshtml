@* EventEase Elite - Events Directory
    Author: Joshua Marc Lourens
    Description: The central hub for administrative event scheduling. 
    Implements a search-driven interface for high-efficiency record retrieval.
*@

@model IEnumerable<EventEase.Models.Event>

<div class="container py-5 mt-4">
    @* --- TOP HEADER ---
       Using the Elite brand pattern with the Hero Glow effect on the 
       primary keyword to establish administrative context.
    *@
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight" style="font-size: 2.5rem; letter-spacing: -1px;">
                OUR <span class="text-primary hero-glow-text">EVENTS</span>
            </h1>
            <p class="text-muted fw-bold small text-uppercase mt-2" style="letter-spacing: 2px;">Administrative Schedule Hub</p>
        </div>
        
        <a asp-action="Create" class="btn btn-brand-elite shadow-sm">
            <i class="bi bi-calendar-plus me-2"></i> Register Event
        </a>
    </div>

    @* --- ELITE SEARCH BAR ---
       This panel allows specialists to query the directory by Event Name 
       or Description, preventing duplicate entries during high-volume periods.
    *@
    <div class="venue-card-manage p-3 mb-5 bg-light border-0 shadow-sm">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0 ps-3 text-muted">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control border-0 bg-transparent fw-bold"
                       placeholder="SEARCH EVENTS BY NAME OR DESCRIPTION..." />
                <button type="submit" class="btn btn-brand-elite px-4 ms-2">SEARCH</button>
                <a asp-action="Index" class="btn btn-white border-0 fw-black small ms-1 pt-2 text-decoration-none">CLEAR</a>
            </div>
        </form>
    </div>

    @* --- EVENTS GRID ---
       Using a flexbox grid to display event cards. Each card implements 
       the lift effect and three-dot management menu.
    *@
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="venue-card-manage p-4 d-flex flex-column h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-black m-0 text-uppercase tracking-tight text-primary">@item.EventName</h4>
                            
                            @* Dropdown: Uses the Elite menu pattern for clean CRUD access *@
                            <div class="dropdown">
                                <button class="btn btn-white btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 rounded-4">
                                    <li><a class="dropdown-item rounded-3 fw-bold small py-2" asp-action="Edit" asp-route-id="@item.EventID"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                    <li><a class="dropdown-item rounded-3 fw-bold small py-2 text-danger" asp-action="Delete" asp-route-id="@item.EventID"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                </ul>
                            </div>
                        </div>

                        <p class="text-muted fw-bold small flex-grow-1">
                            @item.EventDescription
                        </p>

                        <div class="mt-4 pt-3 border-top">
                            <div class="mb-3">
                                <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.65rem;">Schedule Range</div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="stat-pill text-dark">@item.EventStartDate.ToString("dd MMM yyyy")</span>
                                    <i class="bi bi-arrow-right text-muted"></i>
                                    <span class="stat-pill text-dark">@item.EventEndDate.ToString("dd MMM yyyy")</span>
                                </div>
                            </div>
                            <a asp-action="Details" asp-route-id="@item.EventID" class="fw-black text-primary text-decoration-none small">
                                VIEW DETAILS <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-calendar-x text-muted display-1 mb-3"></i>
                <h3 class="fw-black text-muted text-uppercase">No Events Found</h3>
            </div>
        }
    </div>
</div>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. Search Implementation: Use of ViewData for persistent filtering (https://learn.microsoft.com/en-us/aspnet/core/mvc/views/working-with-data)
   2. Bootstrap Flex Grid: Column management for diverse administrative dashboards.
   3. Conditional Rendering: Razor logic for empty state handling (Model.Any()).
   4. UI Typography: Implementation of tracking-tight utilities for SaaS headers.
*@