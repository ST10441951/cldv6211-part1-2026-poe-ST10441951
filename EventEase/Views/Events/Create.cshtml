@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Event</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="EventName" class="form-label fw-bold"></label>
                                <input asp-for="EventName" class="form-control" placeholder="e.g. Sports Day" />
                                <span asp-validation-for="EventName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="BookingID" class="form-label fw-bold">Link to Booking</label>
                                <select asp-for="BookingID" class="form-select" asp-items="ViewBag.BookingID">
                                    <option value="">-- Select a Booking Reference --</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="EventStartDate" class="form-label fw-bold"></label>
                                <input asp-for="EventStartDate" class="form-control" type="date" />
                                <span asp-validation-for="EventStartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EventEndDate" class="form-label fw-bold"></label>
                                <input asp-for="EventEndDate" class="form-control" type="date" />
                                <span asp-validation-for="EventEndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EventDescription" class="form-label fw-bold"></label>
                            <textarea asp-for="EventDescription" class="form-control" rows="3" placeholder="Describe the event..."></textarea>
                            <span asp-validation-for="EventDescription" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">Create Event</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}