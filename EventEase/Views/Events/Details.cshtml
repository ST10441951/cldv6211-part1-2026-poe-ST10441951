@* EventEase Elite - Booking Profile
    Author: Joshua Marc Lourens
    Description: Comprehensive record review. 
    Displays linked Venue and Event details through navigation property mapping.
*@

@model EventEase.Models.Booking

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="venue-card-manage p-5 shadow-sm">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="stat-pill text-primary bg-primary bg-opacity-10 px-3 py-2">RECORD REVIEW</span>
                    <span class="fw-black text-muted">ID: #@Model.BookingID</span>
                </div>
                
                <h1 class="fw-black text-uppercase mb-5 hero-glow-text" style="font-size: 2.8rem; letter-spacing: -1.5px;">
                    BOOKING <span class="text-primary">PROFILE</span>
                </h1>

                @* Split Layout: Providing a high-contrast comparison between
                   the venue location and the associated event data. 
                *@
                <div class="row g-5">
                    <div class="col-md-6 border-end">
                        <div class="mb-4">
                            <div class="fw-black text-muted small text-uppercase mb-1" style="letter-spacing: 1px;">Target Venue</div>
                            <div class="fw-black h4 text-dark">@Model.Venue?.VenueName</div>
                            <div class="text-muted small fw-bold">@Model.Venue?.VenueLocation</div>
                        </div>
                        <div class="mb-0">
                            <div class="fw-black text-muted small text-uppercase mb-1" style="letter-spacing: 1px;">Linked Event</div>
                            <div class="fw-black h4 text-dark">@Model.Event?.EventName</div>
                            <div class="text-muted small fw-bold">@Model.Event?.EventDescription</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="row g-4 mb-4">
                            <div class="col-6">
                                <div class="fw-black text-muted small text-uppercase mb-1">Check In</div>
                                <div class="fw-bold">@Model.BookingStartDate.ToString("dd MMMM yyyy")</div>
                            </div>
                            <div class="col-6">
                                <div class="fw-black text-muted small text-uppercase mb-1">Check Out</div>
                                <div class="fw-bold">@Model.BookingEndDate.ToString("dd MMMM yyyy")</div>
                            </div>
                        </div>
                        <div>
                            <div class="fw-black text-muted small text-uppercase mb-2">Current Clearance</div>
                            <span class="stat-pill bg-dark text-white py-2 px-4 fs-6">@Model.BookingStatus</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 pt-5 mt-5 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.BookingID" class="btn btn-brand-elite px-5">MODIFY RECORD</a>
                    <a asp-action="Index" class="btn btn-white border fw-black small px-4 shadow-sm text-decoration-none pt-2">BACK TO LEDGER</a>
                </div>
            </div>
        </div>
    </div>
</div>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. Navigation Property Loading: Displaying related data via Entity Framework Core.
   2. UI Grid System: Using 50/50 splits for optimal technical data visualization.
   3. String Formatting: Converting DateTime objects into specialist-readable dates.
*@