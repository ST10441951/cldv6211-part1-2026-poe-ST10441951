@model EventEase.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-info text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Event Details</h4>
                </div>
                <div class="card-body p-4">
                    <h2 class="card-title text-primary mb-4">@Model.EventName</h2>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase mb-1">Start Date</h6>
                            <p class="fs-5"><i class="bi bi-calendar-play me-2 text-success"></i>@Html.DisplayFor(m => m.EventStartDate)</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase mb-1">End Date</h6>
                            <p class="fs-5"><i class="bi bi-calendar-x me-2 text-danger"></i>@Html.DisplayFor(m => m.EventEndDate)</p>
                        </div>
                    </div>

                    <div class="mb-3">
                        <h6 class="text-muted text-uppercase mb-1">Description</h6>
                        <p class="fs-5 border-start border-3 border-info ps-3">@Model.EventDescription</p>
                    </div>

                    <div class="mt-5">
                        <h5 class="border-bottom pb-2 mb-3"><i class="bi bi-calendar-check me-2 text-primary"></i>Linked Bookings</h5>
                        
                        @if (Model.Bookings != null && Model.Bookings.Any())
                        {
                            <div class="list-group">
                                @foreach (var booking in Model.Bookings)
                                {
                                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi bi-calendar-event me-2 text-muted"></i>
                                            <strong>@booking.BookingStartDate.ToString("dd MMM yyyy")</strong> to <strong>@booking.BookingEndDate.ToString("dd MMM yyyy")</strong>
                                            
                                            @if (booking.Venue != null)
                                            {
                                                <span class="ms-3 text-muted"><i class="bi bi-geo-alt-fill me-1 text-danger"></i>@booking.Venue.VenueName</span>
                                            }
                                        </div>
                                        
                                        @if (booking.BookingStatus == "Confirmed")
                                        {
                                            <span class="badge bg-success rounded-pill px-3 py-2">@booking.BookingStatus</span>
                                        }
                                        else if (booking.BookingStatus == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">@booking.BookingStatus</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill px-3 py-2">@booking.BookingStatus</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light border text-center text-muted" role="alert">
                                <i class="bi bi-calendar-x mb-2 d-block fs-2"></i>
                                No bookings are currently linked to this event.
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-light p-3">
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back to Events
                        </a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.EventID" class="btn btn-primary px-4">
                                <i class="bi bi-pencil-square me-1"></i>Edit Event
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>