@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings Management";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-journal-check me-2"></i>Bookings Management</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> New Booking
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="d-flex">
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted border-end-0">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0 ps-0" placeholder="Search by Booking ID or Event Name..." />
                    <button type="submit" class="btn btn-primary px-4">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-3">Clear</a>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Booking ID</th>
                        <th>Event</th>
                        <th>Venue</th>
                        <th>Dates</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@item.BookingID</td>
                            <td class="fw-bold text-primary">@item.Event?.EventName</td>
                            <td><i class="bi bi-geo-alt me-1 text-danger"></i>@item.Venue?.VenueName</td>
                            <td>
                                <div class="small">@item.BookingStartDate.ToString("dd MMM yyyy")</div>
                                <div class="text-muted" style="font-size: 0.75rem;">to @item.BookingEndDate.ToString("dd MMM yyyy")</div>
                            </td>
                            <td>
                                @if (item.BookingStatus == "Confirmed")
                                {
                                    <span class="badge bg-success rounded-pill px-3">@item.BookingStatus</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-3">@item.BookingStatus</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.BookingID" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.BookingID" class="btn btn-outline-info"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.BookingID" class="btn btn-outline-danger"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>