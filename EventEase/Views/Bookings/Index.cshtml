@* EventEase Elite - Booking Ledger
    Author: Joshua Marc Lourens
    Description: The central administrative log for monitoring venue allocations.
    Implements explicit routing and automated empty-state handling for clear auditing.
*@

@model IEnumerable<EventEase.Models.Booking>

<div class="container py-5 mt-4">
    @* --- TOP HEADER --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight" style="font-size: 2.5rem; letter-spacing: -1px;">
                BOOKING <span class="text-primary hero-glow-text">LEDGER</span>
            </h1>
            <p class="text-muted fw-bold small text-uppercase mt-2" style="letter-spacing: 2px;">Centralized Conflict Prevention Hub</p>
        </div>
        
        @* FIXED ROUTING: Explicitly targeting the Bookings controller to prevent redirection to Events *@
        <a asp-controller="Bookings" asp-action="Create" class="btn btn-brand-elite shadow-sm">
            <i class="bi bi-calendar-check me-2"></i> Register Booking
        </a>
    </div>

    @* --- SEARCH PANEL (Requirement C) --- *@
    <div class="venue-card-manage p-3 mb-5 bg-light border-0 shadow-sm">
        <form asp-controller="Bookings" asp-action="Index" method="get">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0 ps-3 text-muted">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control border-0 bg-transparent fw-bold"
                       placeholder="SEARCH BY BOOKING ID OR EVENT NAME..." />
                <button type="submit" class="btn btn-brand-elite px-4 ms-2">SEARCH</button>
                <a asp-action="Index" class="btn btn-white border-0 fw-black small ms-1 pt-2 text-decoration-none">RESET</a>
            </div>
        </form>
    </div>

    @* --- LEDGER TABLE / EMPTY STATE --- *@
    <div class="venue-card-manage overflow-hidden border-0 shadow-sm">
        <div class="table-responsive" style="overflow: visible !important;">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4 py-3 fw-black small text-uppercase">ID</th>
                        <th class="py-3 fw-black small text-uppercase">Consolidated Link</th>
                        <th class="py-3 fw-black small text-uppercase">Timeline</th>
                        <th class="py-3 fw-black small text-uppercase">Status</th>
                        <th class="py-3 text-end pe-4 fw-black small text-uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-black text-primary">#@item.BookingID</td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Event?.EventName</div>
                                    <div class="text-muted small fw-bold text-uppercase" style="font-size: 0.7rem;">
                                        <i class="bi bi-geo-alt-fill text-primary me-1"></i> @item.Venue?.VenueName
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold small text-dark">
                                        @item.BookingStartDate.ToString("dd MMM")
                                        <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                        @item.BookingEndDate.ToString("dd MMM yyyy")
                                    </div>
                                </td>
                                <td>
                                    @if (item.BookingStatus == "Confirmed")
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border-success border-opacity-25 border px-3 py-2">CONFIRMED</span>
                                    }
                                    else if (item.BookingStatus == "Cancelled")
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 border px-3 py-2">CANCELLED</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-warning bg-opacity-10 text-dark border-warning border-opacity-25 border px-3 py-2">PENDING</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle shadow-none" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 rounded-4">
                                            <li><a class="dropdown-item rounded-3 fw-bold small py-2" asp-action="Edit" asp-route-id="@item.BookingID"><i class="bi bi-pencil me-2"></i>Modify</a></li>
                                            <li><a class="dropdown-item rounded-3 fw-bold small py-2" asp-action="Details" asp-route-id="@item.BookingID"><i class="bi bi-eye me-2"></i>Review</a></li>
                                            <li><a class="dropdown-item rounded-3 fw-bold small py-2 text-danger" asp-action="Delete" asp-route-id="@item.BookingID"><i class="bi bi-trash me-2"></i>Purge</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-journal-x text-muted display-1 mb-3 d-block"></i>
                                <h3 class="fw-black text-muted text-uppercase">No Bookings Found</h3>
                                <p class="text-muted small fw-bold text-uppercase">Check your search criteria or register a new resource allocation.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. Explicit Route Tag Helpers: Using 'asp-controller' to anchor navigation to the Bookings domain.
   2. Conditional Badge Logic: Enhancing administrative clarity through status-based visual markers.
   3. Table Responsibility: Maintaining column alignment via colspan="5" for empty-state messaging.
   4. Consolidated View: Displaying Venue and Event navigation properties to fulfill Requirement C.
*@