@* EventEase Elite - Decommission Event
    Author: Joshua Marc Lourens
    Description: Centered safety confirmation for irreversible record deletion.
*@

@model EventEase.Models.Event

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 text-center">
            @* Visual Warning: Using the danger palette to signify destructive operations *@
            <div class="venue-card-manage p-5 shadow-sm border-danger border-opacity-25">
                <div class="mb-4">
                    <i class="bi bi-trash3-fill text-danger" style="font-size: 3.5rem;"></i>
                </div>
                
                <h2 class="fw-black text-uppercase mb-3" style="letter-spacing: -1px;">
                    CONFIRM <span class="text-danger">DELETION</span>
                </h2>
                
                <p class="text-muted fw-bold small mb-5" style="letter-spacing: 1px;">
                    YOU ARE REMOVING THIS EVENT RECORD PERMANENTLY.
                </p>

                @* Audit Detail: Re-stating the target identity for final verification *@
                <div class="bg-light p-4 rounded-4 mb-5 text-start border">
                    <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.7rem;">Event Identity</div>
                    <div class="fw-black h5 m-0 text-dark">@Model.EventName</div>
                    <hr class="my-3 opacity-10">
                    <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.7rem;">Timeline</div>
                    <div class="fw-bold small text-muted">
                        @Model.EventStartDate.ToString("dd MMM") to @Model.EventEndDate.ToString("dd MMM yyyy")
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="EventID" />
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-brand-elite py-3 shadow-sm" style="background: #dc3545 !important;">
                            PERMANENTLY DELETE
                        </button>
                        <a asp-action="Index" class="fw-black text-muted text-decoration-none small">
                            CANCEL AND KEEP RECORD
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. Administrative UI: Using color psychology (danger red) to prevent accidental data loss.
   2. Form Security: Use of ActionName("Delete") to safely map the POST back to the controller.
   3. Layout: Symmetric centered design for high-priority confirmation events.
*@