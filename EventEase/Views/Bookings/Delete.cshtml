@* EventEase Elite - Purge Booking
    File Path: Views/Bookings/Delete.cshtml
*@

@model EventEase.Models.Booking

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 text-center">
            <div class="venue-card-manage p-5 shadow-sm border-danger border-opacity-25">
                <div class="mb-4">
                    <i class="bi bi-trash3-fill text-danger" style="font-size: 3.5rem;"></i>
                </div>
                
                <h2 class="fw-black text-uppercase mb-3">CONFIRM <span class="text-danger">PURGE</span></h2>
                <p class="text-muted fw-bold small mb-5">YOU ARE DELETING THIS BOOKING RECORD FROM THE LEDGER.</p>

                <div class="bg-light p-4 rounded-4 mb-5 text-start border">
                    <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.7rem;">Booking Reference</div>
                    <div class="fw-black h5 m-0 text-dark">#@Model.BookingID - @Model.Event?.EventName</div>
                    <hr class="my-3 opacity-10">
                    <div class="fw-black text-muted small text-uppercase mb-1" style="font-size: 0.7rem;">Scheduled Venue</div>
                    <div class="fw-bold small text-muted">@Model.Venue?.VenueName</div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="BookingID" />
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-brand-elite py-3 shadow-sm" style="background: #dc3545 !important;">
                            PERMANENTLY REMOVE
                        </button>
                        <a asp-action="Index" class="fw-black text-muted text-decoration-none small">
                            CANCEL AND KEEP RECORD
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>