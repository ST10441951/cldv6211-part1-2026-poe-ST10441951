@* EventEase Elite - New Booking Record
    File Path: Views/Bookings/Create.cshtml
*@

@model EventEase.Models.Booking

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="venue-card-manage p-5 shadow-sm">
                @* This heading MUST say BOOKING *@
                <h2 class="fw-black text-uppercase mb-4" style="letter-spacing: -1.5px;">
                    NEW <span class="text-primary hero-glow-text">BOOKING</span>
                </h2>
                
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small fw-bold mb-4 py-2"></div>

                    @* VENUE SELECTION *@
                    <div class="mb-3">
                        <label asp-for="VenueID" class="fw-black small text-muted text-uppercase mb-2 d-block">Target Venue</label>
                        <select asp-for="VenueID" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" asp-items="ViewBag.VenueID">
                            <option value="">: SELECT VENUE :</option>
                        </select>
                    </div>

                    @* EVENT SELECTION *@
                    <div class="mb-3">
                        <label asp-for="EventID" class="fw-black small text-muted text-uppercase mb-2 d-block">Associated Event</label>
                        <select asp-for="EventID" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" asp-items="ViewBag.EventID">
                            <option value="">: SELECT EVENT :</option>
                        </select>
                    </div>

                    @* TIMELINE *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="BookingStartDate" class="fw-black small text-muted text-uppercase mb-2 d-block">Start Date</label>
                            <input asp-for="BookingStartDate" type="date" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BookingEndDate" class="fw-black small text-muted text-uppercase mb-2 d-block">End Date</label>
                            <input asp-for="BookingEndDate" type="date" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" />
                        </div>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-brand-elite py-3">CONFIRM BOOKING</button>
                        <a asp-action="Index" class="fw-black text-muted text-center text-decoration-none small">CANCEL AND RETURN</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>