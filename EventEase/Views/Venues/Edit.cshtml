@model EventEase.Models.Venue

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="venue-card-manage p-5 shadow-sm">
                <h2 class="fw-black text-uppercase mb-4" style="letter-spacing: -1.5px;">
                    @(Model?.VenueID > 0 ? "UPDATE" : "REGISTER") <span class="text-primary hero-glow-text">VENUE</span>
                </h2>
                
                <form asp-action="@(Model?.VenueID > 0 ? "Edit" : "Create")" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    @if (Model?.VenueID > 0)
                    {
                        <input type="hidden" asp-for="VenueID" />
                    }

                    <div class="mb-3">
                        <label asp-for="VenueName" class="fw-black small text-muted text-uppercase mb-2 d-block" style="letter-spacing: 1px;">Venue Identity</label>
                        <input asp-for="VenueName" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" placeholder="Grand Hall" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="VenueLocation" class="fw-black small text-muted text-uppercase mb-2 d-block" style="letter-spacing: 1px;">Location</label>
                        <input asp-for="VenueLocation" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" placeholder="Westville Campus" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="VenueCapacity" class="fw-black small text-muted text-uppercase mb-2 d-block" style="letter-spacing: 1px;">Max Capacity</label>
                        <input asp-for="VenueCapacity" class="form-control border-0 bg-light p-3 rounded-4 fw-bold" style="max-width: 140px;" />
                    </div>

                    <div class="p-4 bg-light rounded-4 mb-5 text-center border-dashed">
                        <label class="fw-black small text-primary mb-2 d-block text-uppercase">Cloud Media Upload</label>
                        <input asp-for="ImageFile" type="file" class="form-control form-control-sm border-0 bg-transparent" />
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-brand-elite py-3">CONFIRM SUBMISSION</button>
                        <a asp-action="Index" class="fw-black text-muted text-center text-decoration-none small">CANCEL AND RETURN</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>