@model IEnumerable<EventEase.Models.Venue>

<div class="container py-5 mt-4">
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight" style="font-size: 2.5rem; letter-spacing: -1px;">
                OUR <span class="text-primary hero-glow-text">VENUES</span>
            </h1>
            <p class="text-muted fw-bold small text-uppercase mt-2" style="letter-spacing: 2px;">Internal Administration Hub</p>
        </div>
        
        <a asp-action="Create" class="btn btn-brand-elite shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Register Venue
        </a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="venue-card-manage p-2">
                    <div class="img-container shadow-inner">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light w-100 h-100 d-flex align-items-center justify-content-center">
                                <i class="bi bi-building-fill text-muted fs-1"></i>
                            </div>
                        }
                    </div>

                    <div class="p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h4 class="fw-black m-0 text-truncate" style="max-width: 70%;">@item.VenueName</h4>
                            <div class="dropdown">
                                <button class="btn btn-white btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 rounded-4">
                                    <li><a class="dropdown-item rounded-3 fw-bold small py-2" asp-action="Edit" asp-route-id="@item.VenueID"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                    <li><a class="dropdown-item rounded-3 fw-bold small py-2 text-danger" asp-action="Delete" asp-route-id="@item.VenueID"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                </ul>
                            </div>
                        </div>

                        <p class="text-muted small fw-bold mb-4">
                            <i class="bi bi-geo-alt-fill text-primary me-1"></i> @item.VenueLocation
                        </p>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="stat-pill">
                                <i class="bi bi-people-fill me-1"></i> @item.VenueCapacity
                            </span>
                            <a asp-action="Details" asp-route-id="@item.VenueID" class="fw-black text-primary text-decoration-none small">
                                VIEW DETAILS <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>