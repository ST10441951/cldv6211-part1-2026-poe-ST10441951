@* EventEase Elite - Master Layout 
    Author: Joshua Marc Lourens
    Description: The primary shell for the administrative portal. 
    Implements glassmorphism navigation and global specialist feedback systems.
*@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] : EventEase Elite</title>
    
    @* External CSS: Standard Bootstrap 5 and Google Fonts Nunito API *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <header>
        @* SaaS Navbar: Uses 'fixed-top' for administrative accessibility.
           The 'backdrop-filter' logic is handled in the Elite CSS engine.
        *@
        <nav class="navbar navbar-expand-lg fixed-top">
            <div class="container">
                <a class="navbar-brand fw-black text-uppercase tracking-tight" asp-area="" asp-controller="Home" asp-action="Index">
                    EVENT<span class="text-primary hero-glow-text">EASE</span>
                </a>
                
                @* Mobile Toggle: Borderless design to maintain the clean enterprise aesthetic *@
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-end">
                    <ul class="navbar-nav align-items-center gap-3">
                        @* Navigation Links: Using small-caps and bold weights for a professional SaaS feel *@
                        <li class="nav-item">
                            <a class="nav-link fw-bold small text-dark text-uppercase" asp-controller="Venues" asp-action="Index">Venues</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold small text-dark text-uppercase" asp-controller="Events" asp-action="Index">Events</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold small text-dark text-uppercase" asp-controller="Bookings" asp-action="Index">Bookings</a>
                        </li>
                        
                        @* Primary Action: Distinctive 'Elite' button for core workflow starting point *@
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-brand-elite px-4" asp-controller="Bookings" asp-action="Create">New Booking</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @* Main Content: margin-top: 120px is used to ensure content doesn't
       get hidden behind the fixed glassmorphism navbar.
    *@
    <main role="main" style="margin-top: 120px;">
        <div class="container">
            
            @* Specialist Feedback System: Displays global alerts for error/success states *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm rounded-4 px-4 py-3 mb-4 d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-octagon-fill me-3 fs-4"></i>
                    <span class="fw-bold small text-uppercase">@TempData["ErrorMessage"]</span>
                </div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm rounded-4 px-4 py-3 mb-4 d-flex align-items-center" role="alert">
                    <i class="bi bi-patch-check-fill me-3 fs-4"></i>
                    <span class="fw-bold small text-uppercase">@TempData["SuccessMessage"]</span>
                </div>
            }
        </div>

        @* Razor Placeholder: This is where specific page content (Venues, Events, etc.) is injected *@
        @RenderBody()
    </main>

    @* Footer: Minimalist administrative signature with security protocol access *@
    <footer class="py-5 mt-5 border-top bg-white">
        <div class="container text-center">
            <p class="text-muted fw-bold small text-uppercase mb-3" style="letter-spacing: 1px;">
                © 2026 EventEase Admin Portal : Secure Specialist Infrastructure
            </p>
            <a asp-controller="Home" asp-action="Privacy" class="btn btn-white border fw-black small px-4 shadow-sm text-decoration-none pt-2">
                <i class="bi bi-shield-lock me-2"></i> SECURITY PROTOCOLS
            </a>
        </div>
    </footer>

    @* Standard Core Scripts: jQuery and Bootstrap Bundle *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    @* asp-append-version=true ensures cache-busting when we update our CSS/JS files *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @* View-specific scripts (like validation) are injected here *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@* TECHNICAL REFERENCES
   ---------------------------------------------------
   1. ASP.NET Core Razor Layouts: Microsoft Documentation on shared UI (https://learn.microsoft.com/en-us/aspnet/core/mvc/views/layout)
   2. Tag Helpers: Understanding 'asp-controller' and 'asp-action' (https://learn.microsoft.com/en-us/aspnet/core/mvc/views/tag-helpers/)
   3. Glassmorphism Design: Implementation of 'backdrop-filter' in UI/UX (https://css-tricks.com/almanac/properties/b/backdrop-filter/)
   4. Caching: Use of 'asp-append-version' for Static File Cache Busting (https://www.stevejgordon.co.uk/asp-net-core-tag-helpers-asp-append-version)
   5. Accessibility: Navbar 'fixed-top' patterns for administrative dashboards.
*@