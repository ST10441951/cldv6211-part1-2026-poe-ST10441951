{
    /* EventEase Elite - Global Configuration
     Author: Joshua Marc Lourens
     Description: Core infrastructure settings including database and cloud storage links.
  */

    "Logging": {
        "LogLevel": {
            /* Information level is kept on for local development so we can track 
         EF Core migrations and storage handshakes in the console. */
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    /* AllowedHosts is set to '*' for local dev, but will need restriction 
     once the specialist begins the production cloud migration. */
    "AllowedHosts": "*",

    "ConnectionStrings": {
        /* Main Administrative Database: Pointing to LocalDB for specialist precision. 
       MultipleActiveResultSets (MARS) is enabled to support complex event/venue queries. */
        "EventEaseContext": "Server=(localdb)\\mssqllocaldb;Database=EventEaseContext;Trusted_Connection=True;MultipleActiveResultSets=true",

        /* Cloud Infrastructure: Set to Development Storage for Azurite/Emulator testing.
       This will be replaced with the actual Azure Blob endpoint during Phase 4. */
        "AzureBlobStorage": "UseDevelopmentStorage=true"
    }
}